{
  "name": "@tranzmit/self-serve-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Self-serve infrastructure for Exit Button SDK - auth, billing, admin API",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @tranzmit/exit-button-core build",
    "build:backend": "pnpm --filter @tranzmit/exit-button-backend build",
    "dev": "pnpm --filter @tranzmit/exit-button-backend dev",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vitest/coverage-v8": "^3.1.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "overrides": {
      "livekit-client": "2.15.16"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.14.0",
  "dependencies": {
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0"
  }
}
