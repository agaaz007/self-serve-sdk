{
  "version": 2,
  "buildCommand": "cd packages/backend && npx tsup",
  "outputDirectory": "packages/backend/dist",
  "functions": {
    "packages/backend/dist/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/packages/backend/dist/index.js" }
  ]
}
