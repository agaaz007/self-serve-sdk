{
  "name": "@tranzmit/exit-button-embed",
  "version": "0.1.0",
  "description": "Embeddable Exit Button widget for any website",
  "main": "./dist/index.global.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./embed": "./dist/index.global.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@11labs/client": "^0.2.0",
    "@tranzmit/exit-button-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "license": "MIT"
}
